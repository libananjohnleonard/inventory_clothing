PORT=4000
# Preferred for Supabase/Vercel. Use the Supabase Transaction Pooler connection string.
DATABASE_URL=postgres://postgres.your-project-ref:your-supabase-database-password@aws-0-your-region.pooler.supabase.com:6543/postgres

# Or configure the same connection with separate fields.
DB_HOST=aws-0-your-region.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-database-password
DB_NAME=postgres
DB_SCHEMA=inventory_clothing
DB_SSL=true
DB_POOL_MAX=5
VITE_API_URL=
